generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContractType {
  CLT
  HORISTA
  PJ_FIXO
  PJ_HORISTA
}

enum WorkSchedule {
  SCALE_12X36
  FIXED_220
  CUSTOM
}

enum StartParity {
  PAR
  IMPAR
  NONE
}

enum RegistrationCompany {
  FALCON_SERVICE
  FALCON_MONITORAMENTO
  NAO_REGISTRADO
}

// Enum de papéis/permissões do sistema
enum Role {
  ADMIN    // Acesso total: CRUD de usuários, aprovação de folhas
  MANAGER  // Gerência/Proprietário: aprova folhas, visualiza tudo
  USER     // Operacional/DP: lança ponto, visualiza relatórios
}

model Employee {
  id                   String              @id @default(uuid()) @db.Uuid
  name                 String
  isActive             Boolean             @default(true)
  registrationCompany  RegistrationCompany @default(NAO_REGISTRADO)
  contractType         ContractType
  workSchedule         WorkSchedule
  startParity          StartParity
  hourlyRate           Decimal?            @db.Decimal(10, 2) // Exceção individual; se nulo, usa taxa global

  // Pagamento: PIX
  pixKey               String?
  pixType              String?

  // Pagamento: Método (PIX | BANCARIA | ESPECIE)
  paymentMethod        String?             @default("PIX")

  // Pagamento: Transferência Bancária
  bankName             String?
  bankAgency           String?
  bankAccount          String?

  receivesVA           Boolean             @default(false)
  receivesVT           Boolean             @default(false)
  receivesIntervalHour Boolean             @default(false)
  receivesNightHazard  Boolean             @default(false)
  workLocation         String?
  standardHours        String?
  baseSalary           Decimal?            @db.Decimal(10, 2)
  document             String?

  shifts               Shift[]
  payrollReceipts      PayrollReceipt[]
  monthlyPayrolls      MonthlyPayroll[]
  overtimeEntries      OvertimeEntry[]

  @@map("employees")
}

model Shift {
  id            String   @id @default(uuid()) @db.Uuid
  employeeId    String   @db.Uuid
  referenceDate DateTime @db.Date
  location      String
  checkIn       DateTime?
  checkOut      DateTime?

  employee      Employee @relation(fields: [employeeId], references: [id])

  @@map("shifts")
}

model PayrollReceipt {
  id           String  @id @default(uuid()) @db.Uuid
  employeeId   String  @db.Uuid
  month        Int
  year         Int
  contraCheque Decimal @db.Decimal(10, 2)
  valeTransporte Decimal @db.Decimal(10, 2)
  valoresExtras  Decimal @db.Decimal(10, 2)
  descontos      Decimal @db.Decimal(10, 2)
  observacoes    String? @db.Text
  total          Decimal @db.Decimal(10, 2)

  employee     Employee @relation(fields: [employeeId], references: [id])

  @@map("payroll_receipts")
}

// Histórico de fechamento mensal de folha de pagamento
model MonthlyPayroll {
  id           String   @id @default(uuid()) @db.Uuid
  employeeId   String   @db.Uuid
  month        Int
  year         Int

  // Valores financeiros
  baseValue    Decimal  @db.Decimal(10, 2) @default(0)
  extras       Decimal  @db.Decimal(10, 2) @default(0) // Outras bonificações / Horas Extras
  vtValue      Decimal  @db.Decimal(10, 2) @default(0) // Vale Transporte isolado
  discounts    Decimal  @db.Decimal(10, 2) @default(0)
  total        Decimal  @db.Decimal(10, 2) @default(0)
  observations String?  @db.Text

  // Controle de pagamento
  isPaid       Boolean  @default(false)
  paidAt       DateTime?

  // Aprovação: relação opcional com SystemUser (MANAGER ou ADMIN)
  approvedById String?  @db.Uuid
  approvedAt   DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relações
  employee     Employee   @relation(fields: [employeeId], references: [id])
  approvedBy   SystemUser? @relation(fields: [approvedById], references: [id])

  // Garante que só existe 1 registro por funcionário/mês/ano
  @@unique([employeeId, month, year])
  @@map("monthly_payrolls")
}

model SystemUser {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  username  String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Folhas que este usuário aprovou
  approvedPayrolls MonthlyPayroll[]

  @@map("system_users")
}
// Configurações globais do sistema (chave-valor)
model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

// Controle mensal de Horas Extras
model OvertimeEntry {
  id           String   @id @default(uuid()) @db.Uuid
  employeeId   String   @db.Uuid
  month        Int
  year         Int

  hours        Decimal  @db.Decimal(10, 2) @default(0)
  totalValue   Decimal  @db.Decimal(10, 2) @default(0)
  observations String?  @db.Text
  status       String   @default("PENDENTE") // PENDENTE | PAGO

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee     Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
  @@map("overtime_entries")
}

